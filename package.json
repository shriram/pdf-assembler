{
  "name": "pdf-page-gen",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n vite,express -c cyan,yellow \"vite\" \"tsx watch server/index.ts\"",
    "build": "vite build && tsc -p tsconfig.json && rm -rf dist-server/server/assets && cp -r server/assets dist-server/server/assets",
    "start": "node dist-server/server/index.js"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "marked": "^17.0.5",
    "nanoid": "^5.0.0",
    "open": "^10.1.0",
    "pdf-lib": "^1.17.1",
    "puppeteer-core": "^22.0.0"
  },
  "devDependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
